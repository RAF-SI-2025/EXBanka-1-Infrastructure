{
  "__inputs": [],
  "__requires": [],
  "uid": "exbanka-logs",
  "title": "EXBanka Logs",
  "tags": ["exbanka", "logs"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "service", "refId": "A", "stream": "", "type": 1 },
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {},
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Errors (last 1h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=~\"project-exbanka-instance.\", level=~\"(?i)error\"}[1h]))",
          "legendFormat": "Errors"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 2,
      "title": "Total Log Lines (last 1h)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=~\"project-exbanka-instance.\"}[1h]))",
          "legendFormat": "Total"
        }
      ],
      "options": { "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 3,
      "title": "Instance 1 Log Lines (last 1h)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=\"project-exbanka-instance1\"}[1h]))",
          "legendFormat": "Instance 1"
        }
      ],
      "options": { "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 4,
      "title": "Instance 2 Log Lines (last 1h)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=\"project-exbanka-instance2\"}[1h]))",
          "legendFormat": "Instance 2"
        }
      ],
      "options": { "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 5,
      "title": "Log Volume by Level",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({namespace=~\"project-exbanka-instance.\"}[5m]))",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 1 } }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 6,
      "title": "Log Volume by Service",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({namespace=~\"project-exbanka-instance.\", service=~\"$service\"}[5m]))",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 1 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 7,
      "title": "Errors by Service",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({namespace=~\"project-exbanka-instance.\", service=~\"$service\", level=~\"(?i)error\"}[5m]))",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 1 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 8,
      "title": "Instance 1 — Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{namespace=\"project-exbanka-instance1\", service=~\"$service\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 9,
      "title": "Instance 2 — Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{namespace=\"project-exbanka-instance2\", service=~\"$service\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 10,
      "title": "Error Logs Only",
      "type": "logs",
      "gridPos": { "x": 0, "y": 42, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{namespace=~\"project-exbanka-instance.\", service=~\"$service\", level=~\"(?i)error\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    }
  ]
}
