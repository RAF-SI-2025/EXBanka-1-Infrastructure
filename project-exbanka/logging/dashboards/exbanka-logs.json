{
  "__inputs": [],
  "__requires": [],
  "uid": "exbanka-logs",
  "title": "EXBanka Logs",
  "tags": ["exbanka", "logs"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "label": "Instance",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "namespace", "refId": "A", "stream": "", "type": 1 },
        "multi": false,
        "includeAll": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      },
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "service", "refId": "B", "stream": "{namespace=~\"$namespace\"}", "type": 1 },
        "multi": false,
        "includeAll": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      },
      {
        "name": "level",
        "type": "query",
        "label": "Level",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "level", "refId": "C", "stream": "{namespace=~\"$namespace\"}", "type": 1 },
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Error Rate (last 1h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=~\"$namespace\", service=~\"$service\", level=\"ERROR\"}[1h]))",
          "legendFormat": "Errors"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 2,
      "title": "Warn Rate (last 1h)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=~\"$namespace\", service=~\"$service\", level=\"WARN\"}[1h]))",
          "legendFormat": "Warnings"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 50 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 3,
      "title": "Total Log Lines (last 1h)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=~\"$namespace\", service=~\"$service\"}[1h]))",
          "legendFormat": "Total"
        }
      ],
      "options": { "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 4,
      "title": "Log Volume by Level",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({namespace=~\"$namespace\", service=~\"$service\", level=~\"$level\"}[5m]))",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 1 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "WARN" },  "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "INFO" },  "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "DEBUG" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 5,
      "title": "Log Volume by Service",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({namespace=~\"$namespace\", service=~\"$service\", level=~\"$level\"}[5m]))",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 1 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 6,
      "title": "Errors by Service",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({namespace=~\"$namespace\", service=~\"$service\", level=\"ERROR\"}[5m]))",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 1 }, "color": { "mode": "palette-classic" } }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 7,
      "title": "Instance 1 — All Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{namespace=\"project-exbanka-instance1\", service=~\"$service\", level=~\"$level\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 8,
      "title": "Instance 2 — All Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{namespace=\"project-exbanka-instance2\", service=~\"$service\", level=~\"$level\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 9,
      "title": "Error Logs Only",
      "type": "logs",
      "gridPos": { "x": 0, "y": 42, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{namespace=~\"$namespace\", service=~\"$service\", level=\"ERROR\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    }
  ]
}
