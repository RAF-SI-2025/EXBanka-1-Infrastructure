{
  "__inputs": [],
  "__requires": [],
  "uid": "exbanka-logs",
  "title": "EXBanka Logs",
  "tags": ["exbanka", "logs"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "time": { "from": "now-3h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Total Log Lines (last 1h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=\"project-exbanka-instance1\"}[1h]))",
          "refId": "A",
          "queryType": "instant",
          "legendFormat": "Instance 1"
        }
      ],
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 2,
      "title": "Instance 1 — Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{namespace=\"project-exbanka-instance1\"}",
          "refId": "A",
          "queryType": "range",
          "maxLines": 1000,
          "legendFormat": ""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 3,
      "title": "Instance 2 — Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{namespace=\"project-exbanka-instance2\"}",
          "refId": "A",
          "queryType": "range",
          "maxLines": 1000,
          "legendFormat": ""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 4,
      "title": "Error Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{namespace=~\"project-exbanka-instance1|project-exbanka-instance2\", level=~\"error|ERROR\"}",
          "refId": "A",
          "queryType": "range",
          "maxLines": 1000,
          "legendFormat": ""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    }
  ]
}
